# ── Blockchain ────────────────────────────────────────────────────────────────
EXBT_RPC_URL=http://testnet_rpc.exbotix.net
EXBT_CHAIN_ID=11211
EXBT_HOT_WALLET_KEY=0x_YOUR_PRIVATE_KEY_HERE   # never commit a real key

# ── PostgreSQL (shared with Laravel) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=exbotix
DB_USER=exbotix
DB_PASSWORD=secret
DB_MAX_POOL=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service auth ──────────────────────────────────────────────────────────────
SERVICE_TOKEN_SECRET=change_me_shared_secret_with_laravel
ADMIN_TOKEN=change_me_admin_token

# ── Withdrawal rules ──────────────────────────────────────────────────────────
EXBT_MIN_WITHDRAWAL=1.0
EXBT_WITHDRAWAL_RATE_LIMIT=5        # max per user per rolling hour

# ── Scanner ───────────────────────────────────────────────────────────────────
SCANNER_POLL_INTERVAL_MS=12000
SCANNER_START_BLOCK=0               # 0 = resume from scan_cursor, else override

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3500
NODE_ENV=development
