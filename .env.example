# ============================================
# EXBT Wallet Service - Production Configuration
# ============================================

# Application
NODE_ENV=production
PORT=3500

# Laravel Integration
LARAVEL_URL=https://your-production-domain.com
LARAVEL_API_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_KEY

# Auto-start Listener on boot
AUTO_START_LISTENERS=true

# PostgreSQL Database
DB_HOST=your-db-host.com
DB_PORT=5432
DB_USERNAME=exbt_service
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_DATABASE=exbt_wallet
DB_SYNCHRONIZE=false  # CRITICAL: Must be false in production
DB_LOGGING=false

# Master Encryption Password (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match WALLET_MASTER_PASSWORD in Laravel .env
MASTER_PASSWORD=CHANGE_THIS_TO_64_CHAR_HEX_KEY

# ============================================
# EXBT Chain (EVM)
# ============================================
EXBT_RPC_URL=https://testnet_rpc.exbotix.net
EXBT_CHAIN_ID=11211

# Hot wallet private key — funds withdrawals and seeds gas for sweeps
# CRITICAL: Never commit this value
EXBT_HOT_WALLET_KEY=0x_YOUR_HOT_WALLET_PRIVATE_KEY_HERE

# ============================================
# Scanner
# ============================================
SCANNER_POLL_INTERVAL_MS=60000
# Set to current block on first deploy to skip old history
# Leave 0 to resume from DB cursor on restarts
SCANNER_START_BLOCK=0
# Only scan blocks this many behind chain head — lets RPC fully index before we read
SCANNER_CONFIRMATION_DEPTH=12

# ============================================
# EXBT/USDT Trading (LBank brokerage connector)
# ============================================
TRADING_ENABLED=true
# LBank master account API credentials (the pooled Exbotix account)
LBANK_API_BASE=https://api.lbkex.com
LBANK_WS_URL=wss://www.lbkex.com/ws/V2/
LBANK_API_KEY=YOUR_LBANK_API_KEY
LBANK_API_SECRET=YOUR_LBANK_API_SECRET
# Signing method: HmacSHA256 (key+secret) or RSA (key + PEM private key in LBANK_API_SECRET)
LBANK_SIGN_METHOD=HmacSHA256
LBANK_SYMBOL=exbt_usdt
# Reconciliation poll interval for fills (ms)
TRADE_RECONCILE_INTERVAL_MS=15000
# Extra buffer locked on buy orders to cover taker fee (0.002 = 0.2%)
TRADE_FEE_BUFFER=0.002
# Shared HMAC secret with Laravel for inbound auth on money-moving /api/trading routes
SERVICE_TOKEN_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_KEY

# ============================================
# Security Notes:
# ============================================
# 1. LARAVEL_API_SECRET must match WALLET_API_SECRET in Laravel .env
# 2. Never commit this file to git
# 3. Generate new secrets for each environment
# 4. Keep MASTER_PASSWORD secure — losing it means losing access to all derived addresses
# 5. EXBT_HOT_WALLET_KEY provides FULL ACCESS to the hot wallet
#    - Keep this secret extremely secure
#    - Monitor hot wallet balance regularly
#    - Top up from cold storage as needed
# ============================================
