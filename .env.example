# ── App ───────────────────────────────────────────────────────────────────────
PORT=3500
NODE_ENV=production
AUTO_START_LISTENERS=true

# ── Blockchain ────────────────────────────────────────────────────────────────
EXBT_RPC_URL=https://testnet_rpc.exbotix.net
EXBT_CHAIN_ID=11211
EXBT_HOT_WALLET_KEY=0x_your_hot_wallet_private_key   # never commit

# ── HD Wallet Encryption ──────────────────────────────────────────────────────
# 64-char hex key — must match what Laravel uses to encrypt mnemonics
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_PASSWORD=64_char_hex_string_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=exbotix_wallet
DB_USERNAME=exbotix
DB_PASSWORD=secret
DB_LOGGING=false

# ── Laravel integration ───────────────────────────────────────────────────────
LARAVEL_URL=https://your-laravel-domain.com
LARAVEL_API_SECRET=64_char_hex_shared_secret

# ── Scanner ───────────────────────────────────────────────────────────────────
SCANNER_POLL_INTERVAL_MS=12000
SCANNER_START_BLOCK=0          # 0 = resume from DB cursor
