{
  "info": {
    "name": "EXBT Trading — LBank Connector",
    "description": "Full EXBT/USDT trading module. Public market endpoints need no auth. Money-moving endpoints (orders, accounts) require X-Service-Token HMAC computed by the pre-request script.\n\nSet these collection variables before use:\n  BASE_URL         → http://localhost:3500\n  SERVICE_SECRET   → value of SERVICE_TOKEN_SECRET in .env\n  USER_ID          → any numeric user id for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",       "value": "http://localhost:3500", "type": "string" },
    { "key": "SERVICE_SECRET", "value": "your_service_token_secret_here", "type": "string" },
    { "key": "USER_ID",        "value": "1", "type": "string" },
    { "key": "LAST_ORDER_ID",  "value": "", "type": "string" }
  ],
  "item": [
    {
